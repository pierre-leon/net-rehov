---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ThoughtCard from "../../components/ThoughtCard.astro";
import { getCollection } from "astro:content";
import { SHOW_THOUGHTS } from "../../config";

const posts = (await getCollection("thoughts")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout title="Thoughts" description="Writing by Ishay Rosenthal on product, AI, and design." noindex={!SHOW_THOUGHTS}>
  <div class="pt-32 pb-16 px-6 max-w-4xl mx-auto">
    <p class="text-sm font-semibold text-teal uppercase tracking-widest mb-2">Writing</p>
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Thoughts</h1>
    <p class="text-gray-500 max-w-xl">
      Notes on product leadership, AI/ML, and building things that matter.
    </p>
  </div>

  <section class="px-6 pb-24 max-w-4xl mx-auto">
    {
      posts.length === 0 ? (
        <p class="text-gray-400 text-center py-16">No posts yet. Check back soon.</p>
      ) : (
        <div>
          {posts.map((post) => (
            <ThoughtCard
              slug={post.id}
              title={post.data.title}
              date={post.data.date}
              excerpt={post.data.excerpt}
              heroImage={post.data.heroImage}
              tags={post.data.tags}
            />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>

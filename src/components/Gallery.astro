---
interface Props {
  images: string[];
  title: string;
}

const { images, title } = Astro.props;
---

<div class="gallery">
  {
    images.map((src, i) => (
      <div
        class="gallery-item cursor-pointer overflow-hidden rounded-md bg-gray-100"
        data-index={i}
      >
        <img
          src={src}
          alt={`${title} - image ${i + 1}`}
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
    ))
  }
</div>

<!-- Lightbox -->
<div
  id="lightbox"
  class="fixed inset-0 z-[100] bg-black/90 hidden items-center justify-center"
  role="dialog"
  aria-modal="true"
>
  <button
    id="lb-close"
    class="absolute top-4 right-4 text-white/70 hover:text-white p-2"
    aria-label="Close"
  >
    <i class="fa-solid fa-xmark text-2xl"></i>
  </button>
  <button
    id="lb-prev"
    class="absolute left-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white p-2"
    aria-label="Previous"
  >
    <i class="fa-solid fa-chevron-left text-2xl"></i>
  </button>
  <button
    id="lb-next"
    class="absolute right-12 top-1/2 -translate-y-1/2 text-white/70 hover:text-white p-2"
    aria-label="Next"
  >
    <i class="fa-solid fa-chevron-right text-2xl"></i>
  </button>
  <img
    id="lb-img"
    src=""
    alt=""
    class="max-w-[90vw] max-h-[85vh] object-contain rounded"
  />
</div>

<style>
  .gallery {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
  }

  .gallery-item {
    aspect-ratio: 4/3;
  }

  .gallery-item:first-child {
    grid-column: 1 / -1;
    aspect-ratio: 16/9;
  }

  @media (min-width: 640px) {
    .gallery {
      grid-template-columns: 1fr 1fr;
    }
    .gallery-item:first-child {
      grid-column: 1 / -1;
    }
  }
</style>

<script>
  const images = Array.from(document.querySelectorAll<HTMLImageElement>(".gallery-item img")).map(
    (img) => img.src,
  );

  const lightbox = document.getElementById("lightbox")!;
  const lbImg = document.getElementById("lb-img") as HTMLImageElement;
  let current = 0;

  function open(index: number) {
    current = index;
    lbImg.src = images[current];
    lightbox.classList.remove("hidden");
    lightbox.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function close() {
    lightbox.classList.add("hidden");
    lightbox.classList.remove("flex");
    document.body.style.overflow = "";
  }

  function prev() {
    open((current - 1 + images.length) % images.length);
  }

  function next() {
    open((current + 1) % images.length);
  }

  document.querySelectorAll(".gallery-item").forEach((item, i) => {
    item.addEventListener("click", () => open(i));
  });

  document.getElementById("lb-close")!.addEventListener("click", close);
  document.getElementById("lb-prev")!.addEventListener("click", prev);
  document.getElementById("lb-next")!.addEventListener("click", next);
  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) close();
  });

  document.addEventListener("keydown", (e) => {
    if (!lightbox.classList.contains("flex")) return;
    if (e.key === "Escape") close();
    if (e.key === "ArrowLeft") prev();
    if (e.key === "ArrowRight") next();
  });
</script>
